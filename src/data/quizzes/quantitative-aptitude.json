  {"id": "qa-001", "question": "What is 15% of 200?", "options": ["20", "25", "30", "35"], "correct": 2, "explanation": "15% of 200 = (15/100) × 200 = 30", "difficulty": "easy", "exam": ["upsc", "ssc-cgl"], "topic": "Percentage"},
  {"id": "qa-002", "question": "If a car travels 60 km in 2 hours, what is its speed?", "options": ["20 km/h", "30 km/h", "40 km/h", "60 km/h"], "correct": 1, "explanation": "Speed = Distance/Time = 60/2 = 30 km/h", "difficulty": "easy", "exam": ["upsc", "ssc-cgl"], "topic": "Speed & Distance"},
  {"id": "qa-003", "question": "What is the square root of 144?", "options": ["10", "12", "14", "16"], "correct": 1, "explanation": "√144 = 12 (because 12 × 12 = 144)", "difficulty": "easy", "exam": ["upsc", "ssc-cgl"], "topic": "Square Root"},
  {"id": "qa-004", "question": "If 5 workers can complete a job in 10 days, how many days will 10 workers take?", "options": ["5 days", "10 days", "15 days", "20 days"], "correct": 0, "explanation": "If workers double, time is halved. 10 days / 2 = 5 days", "difficulty": "medium", "exam": ["upsc", "ssc-cgl"], "topic": "Work & Time"},
  {"id": "qa-005", "question": "What is 25% of 80?", "options": ["15", "18", "20", "25"], "correct": 2, "explanation": "25% of 80 = (25/100) × 80 = 20", "difficulty": "easy", "exam": ["upsc", "ssc-cgl"], "topic": "Percentage"},
  {"id": "qa-006", "question": "If x + 5 = 12, what is x?", "options": ["5", "7", "10", "12"], "correct": 1, "explanation": "x = 12 - 5 = 7", "difficulty": "easy", "exam": ["upsc", "ssc-cgl"], "topic": "Algebra"},
  {"id": "qa-007", "question": "What is the average of 10, 20, 30, and 40?", "options": ["20", "25", "30", "35"], "correct": 2, "explanation": "Average = (10 + 20 + 30 + 40) / 4 = 100 / 4 = 25", "difficulty": "easy", "exam": ["upsc", "ssc-cgl"], "topic": "Average"},
  {"id": "qa-008", "question": "If the ratio of A:B is 3:4 and A = 9, what is B?", "options": ["12", "16", "18", "24"], "correct": 0, "explanation": "A:B = 3:4, so 3x = 9 means x = 3. Therefore B = 4x = 12", "difficulty": "medium", "exam": ["upsc", "ssc-cgl"], "topic": "Ratio & Proportion"},
  {"id": "qa-009", "question": "What is 12 × 13?", "options": ["145", "150", "156", "160"], "correct": 2, "explanation": "12 × 13 = 156", "difficulty": "easy", "exam": ["upsc", "ssc-cgl"], "topic": "Multiplication"},
  {"id": "qa-010", "question": "If a book costs ₹200 and there's a 20% discount, what is the final price?", "options": ["₹140", "₹160", "₹180", "₹190"], "correct": 1, "explanation": "Discount = 20% of 200 = ₹40. Final price = 200 - 40 = ₹160", "difficulty": "easy", "exam": ["upsc", "ssc-cgl"], "topic": "Discount"},
  {"id": "qa-011", "question": "What is the LCM of 12 and 18?", "options": ["24", "36", "48", "72"], "correct": 1, "explanation": "Multiples of 12: 12, 24, 36... Multiples of 18: 18, 36... LCM = 36", "difficulty": "medium", "exam": ["upsc", "ssc-cgl"], "topic": "Number Theory"},
  {"id": "qa-012", "question": "If 2x = 10, what is 3x?", "options": ["10", "12", "15", "20"], "correct": 2, "explanation": "2x = 10 means x = 5. Therefore 3x = 15", "difficulty": "easy", "exam": ["upsc", "ssc-cgl"], "topic": "Algebra"},
  {"id": "qa-013", "question": "What is the sum of angles in a triangle?", "options": ["90°", "180°", "270°", "360°"], "correct": 1, "explanation": "The sum of all angles in any triangle is 180 degrees.", "difficulty": "easy", "exam": ["upsc", "ssc-cgl"], "topic": "Geometry"},
  {"id": "qa-014", "question": "If a man walks 5 km east and then 3 km north, what is the straight-line distance from start?", "options": ["8 km", "5.83 km", "4 km", "√34 km"], "correct": 3, "explanation": "Using Pythagoras: Distance = √(5² + 3²) = √34 km ≈ 5.83 km", "difficulty": "hard", "exam": ["upsc"], "topic": "Geometry"},
  {"id": "qa-015", "question": "What is 40% of 250?", "options": ["80", "90", "100", "110"], "correct": 2, "explanation": "40% of 250 = (40/100) × 250 = 100", "difficulty": "easy", "exam": ["upsc", "ssc-cgl"], "topic": "Percentage"},
  {"id": "qa-016", "question": "If 3 apples cost ₹30, what is the cost of 7 apples?", "options": ["₹60", "₹70", "₹80", "₹90"], "correct": 2, "explanation": "Cost per apple = 30/3 = ₹10. For 7 apples = 7 × 10 = ₹70", "difficulty": "easy", "exam": ["upsc", "ssc-cgl"], "topic": "Arithmetic"},
  {"id": "qa-017", "question": "What is the GCD of 24 and 36?", "options": ["6", "12", "18", "24"], "correct": 1, "explanation": "Factors of 24: 1,2,3,4,6,8,12,24. Factors of 36: 1,2,3,4,6,9,12,18,36. GCD = 12", "difficulty": "medium", "exam": ["upsc"], "topic": "Number Theory"},
  {"id": "qa-018", "question": "If 2x + 3 = 11, what is x?", "options": ["2", "4", "6", "8"], "correct": 1, "explanation": "2x = 11 - 3 = 8, so x = 4", "difficulty": "easy", "exam": ["upsc", "ssc-cgl"], "topic": "Algebra"},
  {"id": "qa-019", "question": "What is the perimeter of a square with side 5 cm?", "options": ["10 cm", "15 cm", "20 cm", "25 cm"], "correct": 2, "explanation": "Perimeter = 4 × side = 4 × 5 = 20 cm", "difficulty": "easy", "exam": ["upsc", "ssc-cgl"], "topic": "Geometry"},
  {"id": "qa-020", "question": "If a company's revenue increased by 50% from ₹100 crore to ₹150 crore, what was the increase?", "options": ["₹30 crore", "₹40 crore", "₹50 crore", "₹60 crore"], "correct": 2, "explanation": "Increase = 150 - 100 = ₹50 crore. Percentage increase = (50/100) × 100 = 50%", "difficulty": "easy", "exam": ["upsc", "ssc-cgl"], "topic": "Percentage"}
